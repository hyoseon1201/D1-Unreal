root = true

[*]
charset = utf-8
end_of_line = crlf
insert_final_newline = true
trim_trailing_whitespace = true

[*.{cpp,h,cs}]
indent_style = tab
indent_size = 4
tab_width = 4

[*.md]
indent_style = space
indent_size = 2

[*.uproject]
indent_style = space
indent_size = 2

[*.ini]
indent_style = space
indent_size = 2
